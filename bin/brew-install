#!/bin/bash

set -e

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Detect Apple Silicon vs Intel by hardware, not process architecture.
# sysctl gives the true hardware answer even when running under Rosetta.
if [[ "$(sysctl -n hw.optional.arm64 2>/dev/null)" == "1" ]]; then
  BREW_PREFIX="/opt/homebrew"
  BREW_ARCH="arch -arm64"
else
  BREW_PREFIX="/usr/local"
  BREW_ARCH=""
fi

BREW="$BREW_PREFIX/bin/brew"

# Install Homebrew if not present at the native prefix
if [[ ! -x "$BREW" ]]; then
  echo "Homebrew not found at $BREW_PREFIX. Installing..."
  $BREW_ARCH /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Install all packages from Brewfile
echo "Installing packages from Brewfile…"
$BREW_ARCH "$BREW" bundle --file="$DOTFILES_DIR/Brewfile" --no-upgrade

# Set default shell to /bin/zsh if not already
CURRENT_SHELL="$(dscl . -read "/Users/$USER" UserShell | awk '{print $2}')"
if [[ "$CURRENT_SHELL" != "/bin/zsh" ]]; then
  echo "Setting default shell to /bin/zsh…"
  chsh -s /bin/zsh
  echo "Shell changed. Open a new terminal to use /bin/zsh."
fi
