#!/bin/bash

# Deletes local branches merged into the given target branch (main, master, develop, or release*),
# then prompts before doing the same for remote branches.

BRANCH=$1

PROTECTED='main$|master$|develop$|^hotfix.+$|^release.+$'

if [[ "$BRANCH" == "main" || "$BRANCH" == "master" || "$BRANCH" == "develop" || "$BRANCH" =~ release.+ || "$BRANCH" =~ hotfix.+ ]]; then
  printf "Reaping branches merged into %s\n\n" "$BRANCH"

  git checkout $BRANCH
  git fetch
  git remote prune origin

  echo "Remove fully merged local branches..."
  git branch --merged $BRANCH | grep -E -v "$PROTECTED" | xargs git branch -d

  echo "The following remote branches are fully merged and will be removed:"
  git branch -r --merged $BRANCH | sed 's/ *origin\///' | grep -E -v "$PROTECTED"

  read -p "Continue (y/n)? "
  if [ "$REPLY" == "y" ]; then
    git branch -r --merged $BRANCH | sed 's/ *origin\///' \
      | grep -E -v "$PROTECTED" | xargs -I% git push origin :%
    echo "Done!"
  fi
else
  printf "Usage: git reap <main|master|develop|hotfix*|release*>\n\n"
fi
